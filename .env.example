# Base de données PostgreSQL (Neon)
# Créer un compte sur https://neon.tech, copier la connection string
DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require

# Clé secrète Payload (générer avec: openssl rand -hex 32)
PAYLOAD_SECRET=votre-cle-secrete-tres-longue-et-aleatoire

# Vercel Blob (stockage photos)
# Configurer dans le dashboard Vercel > Storage > Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Resend (envoi d'emails)
# Créer un compte sur https://resend.com, créer une API key
RESEND_API_KEY=re_xxxxx

# Email de l'association (pour recevoir les messages de contact)
CONTACT_EMAIL=contact@abms06jb.info

# URL du site (en production, mettre l'URL Vercel ou le domaine)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
